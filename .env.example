ANTHROPIC_API_KEY=sk-ant-your-key-here

# Sentry error monitoring (optional — app builds and runs without these)
# Create a project at https://sentry.io and copy the DSN from Settings > Projects > <project> > DSN

# Client-side DSN (injected into browser bundle at build time)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Server-side DSN (kept secret — not embedded in client bundle)
# Can reuse the same DSN value as NEXT_PUBLIC_SENTRY_DSN if you have one project
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry org + project slugs (required for sourcemap uploads — see sentry.io dashboard)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Sentry CLI auth token for sourcemap uploads during `next build` (CI only)
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_your-token-here
