{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/drip?day=1",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/drip?day=3",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/drip?day=7",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/day2-nudge",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/first-agon-recap",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 0"
    }
  ]
}
