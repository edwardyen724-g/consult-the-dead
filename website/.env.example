# Optional. If set, contact form submissions are POSTed to this Discord
# webhook as an embed. Get one from: Discord channel → Edit Channel →
# Integrations → Webhooks → New Webhook → Copy Webhook URL.
# If unset, submissions are logged to the Vercel function output instead.
DISCORD_WEBHOOK_URL=

# Optional. If set, Agora research fetches actual page content from URLs
# mentioned in questions AND does deep web searches via Tavily.
# Get a free key (1,000 req/month) at https://app.tavily.com/
# Falls back to Claude's built-in web_search if unset.
TAVILY_API_KEY=

# Required for POST /api/emails/subscribe (Beehiiv newsletter capture).
# Get your API key from https://app.beehiiv.com/settings/integrations
# and your Publication ID from the Publication settings page.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Optional. Sentry error monitoring (https://sentry.io).
# Set both variables in Vercel → Project → Settings → Environment Variables.
# When absent the Sentry SDK is imported but no-ops, so the app builds and
# runs cleanly without a Sentry project configured.
#
# NEXT_PUBLIC_SENTRY_DSN is embedded in the browser bundle at build time.
# SENTRY_DSN is a server-only secret used by server and edge runtimes.
# Both should point to the same DSN; keeping them separate lets you rotate
# the server secret without a client redeploy.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=consult-the-dead
# SENTRY_AUTH_TOKEN is used only during `next build` to upload source maps.
# Generate one at https://sentry.io/settings/auth-tokens/ with
# project:releases and org:read scopes.
SENTRY_AUTH_TOKEN=
