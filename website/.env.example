# Optional. If set, contact form submissions are POSTed to this Discord
# webhook as an embed. Get one from: Discord channel → Edit Channel →
# Integrations → Webhooks → New Webhook → Copy Webhook URL.
# If unset, submissions are logged to the Vercel function output instead.
DISCORD_WEBHOOK_URL=

# Optional. If set, Agora research fetches actual page content from URLs
# mentioned in questions AND does deep web searches via Tavily.
# Get a free key (1,000 req/month) at https://app.tavily.com/
# Falls back to Claude's built-in web_search if unset.
TAVILY_API_KEY=
